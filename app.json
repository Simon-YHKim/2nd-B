{
  "expo": {
    "name": "2nd-Brain",
    "slug": "2nd-brain",
    "owner": "simon_k",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "secondbrain",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/439c4c86-39a7-4a47-8bfa-0426f9fe18c9",
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "preview"
      }
    },
    "ios": {
      "bundleIdentifier": "com.simonk.secondbrain",
      "icon": "./assets/images/icon.png",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "The app needs camera access to capture documents for OCR and memory storage.",
        "NSPhotoLibraryUsageDescription": "The app needs photo library access to upload existing images for memory analysis.",
        "NSUserTrackingUsageDescription": "Allow tracking so the ads you see are more relevant to you. Declining does not change how the app works.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.simonk.secondbrain",
      "googleServicesFile": "./google-services.json",
      "versionCode": 7,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_HEART_RATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#070A18",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "secondbrain"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "2nd-Brain",
      "shortName": "2nd-Brain",
      "themeColor": "#070A18",
      "backgroundColor": "#070A18",
      "display": "standalone"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "extraMavenRepos": [
              "https://devrepo.kakao.com/nexus/content/groups/public/"
            ],
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./config-plugins/withAndroidAbiFilter",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#070A18",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs photo library access so you can pick an image for OCR capture.",
          "cameraPermission": "The app needs camera access to take a photo for OCR capture."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "The app uses your calendar only to add routine items you approve on screen.",
          "remindersPermission": "The app does not use your reminders. iOS shows this because the calendar library includes reminder features."
        }
      ],
      "expo-notifications",
      "expo-image",
      "react-native-health-connect",
      "expo-health-connect",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "The app reads your activity and routines only to tick off goals you approve on screen.",
          "NSHealthUpdateUsageDescription": "The app does not write to Health. iOS requires this notice alongside the app's Health read access.",
          "background": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "The app needs microphone access to record a voice memo and turn it into text you can save."
        }
      ],
      "expo-sharing",
      "@react-native-google-signin/google-signin",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "b1e5bae63789540f943809288822663b",
          "kotlinVersion": "2.1.20"
        }
      ],
      "expo-asset",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9656418583974410~9222223784",
          "iosAppId": "ca-app-pub-9656418583974410~1703514773",
          "delayAppMeasurementInit": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/2nd-B"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "439c4c86-39a7-4a47-8bfa-0426f9fe18c9"
      }
    }
  }
}
