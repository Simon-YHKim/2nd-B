{
  "route": "/wiki",
  "modes": [
    "wikiHome",
    "wikiPage",
    "records",
    "recordDetail",
    "search",
    "empty"
  ],
  "sections": [
    {
      "id": "header",
      "height": 94,
      "safeArea": true
    },
    {
      "id": "searchBar",
      "height": 64,
      "sticky": true
    },
    {
      "id": "filterChips",
      "height": 44,
      "optional": true
    },
    {
      "id": "contentList",
      "scroll": true
    },
    {
      "id": "referenceDrawer",
      "type": "bottomSheet",
      "optional": true
    }
  ],
  "handoff": {
    "toJarvis": {
      "entry": "wiki",
      "wikiPageId": "string?",
      "recordId": "string?",
      "referenceRecordIds": "string[]"
    },
    "toGraph": {
      "entry": "knowledgeItem",
      "highlightRecordId": "string",
      "highlightWikiPageId": "string?"
    }
  }
}