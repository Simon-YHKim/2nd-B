# 2nd-Brain — environment template
# Copy to .env and fill in. NEVER commit .env.

# === Supabase (C3/C4/C5/C6/C8/C10) ===
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# === Gemini / Vertex AI (C1/C2) ===
# Set USE_VERTEX=true and provide GOOGLE_CLOUD_PROJECT to satisfy C2.
# When USE_VERTEX=false, falls back to Google AI Studio API key (dev only).
EXPO_PUBLIC_USE_VERTEX=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_API_KEY=

# === LLM routing (D-26, docs/LLM-ROUTING.md) ===
# Phase gate for purpose-keyed vendor routing.
#   1 (or unset) = Phase 1: 100% Gemini backbone (XPRIZE-safe, $0/mo default)
#   2            = Phase 2: Anthropic/OpenAI seats activate for their purposes.
#                  Requires ANTHROPIC_API_KEY / OPENAI_API_KEY set as Supabase
#                  Edge Function secrets and claude-proxy / openai-proxy
#                  deployed. Client never holds vendor keys (C1).
EXPO_PUBLIC_LLM_PHASE=1

# === Observability (Sprint 1) ===
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# Web usage analytics (public client ids, not secrets). Both no-op until set,
# and only load after the user enables "External analytics" in privacy settings.
# GA4: the "G-XXXXXXX" Measurement ID. Clarity: the project id from clarity.microsoft.com.
EXPO_PUBLIC_GA4_MEASUREMENT_ID=
EXPO_PUBLIC_CLARITY_PROJECT_ID=

# === Testing / QA: subscription paywall override ===
# Temporarily unlock ALL subscription-gated features for every user (free-tier
# journal/note caps, the chat daily cap, and premium-only features). Single
# switch that flips the whole paywall on/off.
#   off    = restore real per-user billing gating (DEFAULT, launch/release)
#   brain  = everything unlocked (testing-phase paywall bypass; set explicitly)
#   soma | cortex | free = pin everyone to that tier to test a paywall boundary
EXPO_PUBLIC_FORCE_TIER=off
