# 2nd-Brain — environment template
# Copy to .env and fill in. NEVER commit .env.

# === Supabase (C3/C4/C5/C6/C8/C10) ===
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# === Gemini / Vertex AI (C1/C2) ===
# Set USE_VERTEX=true and provide GOOGLE_CLOUD_PROJECT to satisfy C2.
# When USE_VERTEX=false, falls back to Google AI Studio API key (dev only).
EXPO_PUBLIC_USE_VERTEX=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_API_KEY=

# === Observability (Sprint 1) ===
SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
