# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# context-guardian (per-session state, not committed)
SESSION_RECOVERY.md
context_limit_log.json

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*
.codex-run/

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.local
.env*.local

# typescript
*.tsbuildinfo

# jest / coverage
coverage/

# tsx cache
.tsx

# Claude Code per-user settings (project-level shared settings.json stays tracked)
.claude/settings.local.json
.claude/local/

# generated native folders
/ios
/android
.gstack/

# Local-only dev artifacts (never commit)
.claude/launch.json
.tmp_hq_pack/

# stray env backups (never commit)
.env.bak
.env.*.bak
.env.local

# root probe scripts dropped by concurrent agents (never commit)
test_*.js
.codex-*.md
.ag-*.md

# stray hub paths accidentally written by AI worktrees (belong in C:/Coding/AI Infra/Communication)
/agents/
